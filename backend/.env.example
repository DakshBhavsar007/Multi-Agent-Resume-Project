# ── Application Configuration ──────────────────────────────────────────────────
APP_NAME=Vishleshan Resume Intelligence API
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-secret-string-in-production
JWT_SECRET=change-me-to-a-long-random-secret-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── PostgreSQL Database ───────────────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=vishleshan
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_db_password_here@127.0.0.1:5432/vishleshan

# ── Redis & Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
# REDIS_PASSWORD=your_redis_password_here

# ── Machine Learning & Vector Search (ChromaDB) ───────────────────────────────
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_COLLECTION_RESUMES=resumes
CHROMA_COLLECTION_JOBS=job_descriptions
CHROMA_PERSIST_DIR=./chroma_data
EMBEDDING_MODEL=models/embedding-001
EMBEDDING_DIMENSION=768
HF_SPACE_EMBEDDING_URL=https://huggingface.co/spaces/username/repo-name

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Primary: Google Gemini API keys
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.1

# Fallback: Groq Cloud API
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback: Local Ollama Model
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_FALLBACK_MODEL=mistral
OLLAMA_TIMEOUT=120

# ── OAuth Authentication ──────────────────────────────────────────────────────
# Google OAuth 2.0
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── Third-Party Integrations ──────────────────────────────────────────────────
# Razorpay payment keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Brevo Marketing API / SMTP
BREVO_API_KEY=your_brevo_api_key_here
MAIL_FROM=noreply@yourdomain.com

# ── File Upload limits ────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
PHOTO_DIR=./photos
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx,doc,txt

# ── Rate Limits & Webhooks ────────────────────────────────────────────────────
RATE_LIMIT_FREE=50
RATE_LIMIT_PREMIUM=5000
RATE_LIMIT_ENTERPRISE=50000
WEBHOOK_SECRET=change-this-webhook-signing-secret
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=3

# ── Paths configuration ───────────────────────────────────────────────────────
SKILL_TAXONOMY_PATH=./data/skill_taxonomy.json
SAMPLE_JOBS_PATH=./data/sample_jobs.json
